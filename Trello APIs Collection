      "name": "Create a board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();\r",
              "pm.environment.set(\"boardID\", jsonData.id);\r",
              "\r",
              "pm.test(\"Response has id\", function () {\r",
              "    pm.expect(jsonData).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Response has name\", function () {\r",
              "    pm.expect(jsonData).to.exist;\r",
              "});\r",
              "\r",
              "pm.test(\"Response has url\", function () {\r",
              "    pm.expect(jsonData).to.exist;\r",
              "});\r",
              "let createboardname = pm.environment.get(\"myboardname\");\r",
              "pm.test(\"Correct Board Value\", function () {\r",
              "    pm.expect(jsonData.name).to.eql(createboardname);\r",
              "});\r",
              "\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});"
