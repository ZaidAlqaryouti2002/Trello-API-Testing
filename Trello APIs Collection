            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generates a random number and creates the string\r",
              "const randomId = Math.floor(Math.random() * 1000);\r",
              "const boardName = `myboard${randomId}`;\r",
              "\r",
              "// Save it to a local variable\r",
              "pm.environment.set(\"myboardname\", boardName);"
            ],
